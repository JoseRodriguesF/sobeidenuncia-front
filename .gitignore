# ==========================================
# SOBEI Portal — .gitignore
# ==========================================

# ---- Dependências ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Build & Output ----
/.next/
/out/
/build
/dist

# ---- Testes ----
/coverage

# ---- Variáveis de ambiente (SENSÍVEL) ----
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Chaves e certificados (SENSÍVEL) ----
*.pem
*.key
*.crt
*.p12
*.pfx

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---- Sistema operacional ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~

# ---- IDEs e editores ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ---- Vercel / Deploy ----
.vercel

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Misc ----
*.bak
*.tmp
*.temp
.antigravitycli
.antigravity

# ---- Pastas Locais Ignoradas ----
/BD/
/Caso de uso/
/Prototipo/
